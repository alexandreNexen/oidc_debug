PORT=3000
NODE_ENV=production
# BASE_URL is the CANONICAL public URL of the backend. It is the ONLY source of
# truth for OIDC redirect_uri and SAML ACS URL construction.
# In local dev, set it to the backend's own URL (typically http://localhost:3000).
# NEVER set it to the Vite dev server URL (http://127.0.0.1:5173) — that would
# make the app advertise a redirect_uri that the IdP does not recognize.
BASE_URL=http://localhost:8080
SESSION_SECRET=change-me-dev-only
LOG_LEVEL=info
STORAGE_DIR=/data
EZ_ACCESS_PREPROD_DISCOVERY_URL=
EZ_ACCESS_PROD_DISCOVERY_URL=
